# ── Mobile app environment variables ────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Variables must start with EXPO_PUBLIC_ to be accessible in the app bundle.
# NEVER commit .env — it is already in .gitignore.

# ── API Server URL ───────────────────────────────────────────────────────────
# Points the mobile app at the backend.
#
# LOCAL DEVELOPMENT (most common):
#   1. Start the api-server (cd artifacts/api-server && pnpm dev)
#   2. Find your machine's LAN IP: run `ipconfig` (Windows) or `ifconfig` (Mac/Linux)
#   3. Use that IP — localhost won't work because the device/emulator is separate
#
#   Android emulator:       EXPO_PUBLIC_API_BASE=http://10.0.2.2:3000
#   Physical device (LAN):  EXPO_PUBLIC_API_BASE=http://192.168.1.x:3000
#   iOS simulator:          EXPO_PUBLIC_API_BASE=http://localhost:3000
#
# PRODUCTION (Railway / Render / etc.):
#   EXPO_PUBLIC_API_BASE=https://your-api-deployment-url.up.railway.app
#
EXPO_PUBLIC_API_BASE=http://10.0.2.2:3000

# ── Sentry error monitoring ──────────────────────────────────────────────────
# Optional but strongly recommended for production.
# When set, crashes and unhandled errors are sent to Sentry.
# Get your DSN at: https://sentry.io → Project Settings → Client Keys (DSN)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
