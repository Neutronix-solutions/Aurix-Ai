# ── Required in production ──────────────────────────────────────────────────

# JWT signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/aurixai

PORT=3000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://app.aurixai.com

# ── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── AI Provider (at least ONE required for AI Coach + Chat) ─────────────────
# The server tries each in order: OpenAI → Anthropic → Gemini → static fallback.
# You only need ONE key — add whichever you have access to.
#
# Option A: OpenAI  →  https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
#
# Option B: Anthropic Claude (free trial available)  →  https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option C: Google Gemini (FREE, no credit card needed)  →  https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# ── Email OTP (at least ONE required for email verification) ─────────────────
# Option A: Resend (RECOMMENDED — free 3 000 emails/month, no credit card)
#   1. Go to https://resend.com → Sign up free → API Keys → Create Key
#   2. Uncomment RESEND_API_KEY below and paste your key.
#   3. RESEND_FROM: must use a domain YOU own and have verified at resend.com/domains.
#      Personal addresses (@gmail, @outlook, @hotmail) are rejected by Resend with 403.
#      Leave RESEND_FROM commented out to use Resend's shared "onboarding@resend.dev"
#      sender — works immediately for testing but ONLY delivers to your Resend account email.
# RESEND_API_KEY=re_...
# Domain neutronixs.com is verified — use it as the sender:
RESEND_FROM=Aurix AI <noreply@neutronixs.com>
#
# Option B: SMTP fallback (any provider — Gmail app password, Mailtrap, Postmark, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   ← Gmail App Password (not your account password)
# SMTP_FROM=noreply@aurixai.app

# ── SMS OTP via Twilio ───────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Sentry ───────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Deep health check token ─────────────────────────────────────────────────
# HEALTH_TOKEN=CHANGE_ME_openssl_rand_hex_32
